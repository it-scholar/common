%% =============================================================================
%% bcpedu-colors.sty — Color Palette for BCP Education Books
%% =============================================================================
%% Defines all named colors used throughout the template.
%% Two modes:
%%   [digital] — full color (default)
%%   [print]   — maps backgrounds to white/light-gray, text accents to near-black
%%
%% Usage: loaded automatically by bcpedu.cls
%% Manual: \usepackage[print]{bcpedu-colors}
%% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bcpedu-colors}[2026/07/08 v1.0 BCP Education Color Palette]

\RequirePackage{xcolor}

\newif\if@bcpcolorprint
\DeclareOption{print}{\@bcpcolorprinttrue}
\DeclareOption{digital}{\@bcpcolorprintfalse}
\ProcessOptions\relax

%% ─── Base neutral palette (shared, mode-independent) ─────────────────────────
\definecolor{bcpBlack}    {HTML}{1F1F1F}   % near-black body text
\definecolor{bcpDarkGray} {HTML}{3A3A3A}   % secondary text, captions
\definecolor{bcpMidGray}  {HTML}{5A5A5A}   % light text, footnotes
\definecolor{bcpLightGray}{HTML}{AAAAAA}   % disabled/placeholder text
\definecolor{bcpRule}     {HTML}{CCCCCC}   % horizontal rules, borders
\definecolor{bcpPageBg}   {HTML}{FFFFFF}   % page background

%% ─── Primary accent: warm golden amber ──────────────────────────────────────
%% Clean, modern amber palette — editorial warmth, clean contrast.
%% Individual books can override \colorlet{bcpAccent}{...} after loading the class.
\definecolor{bcpAccentBase}  {HTML}{CA8208}   % golden amber (headings, rules, labels)
\definecolor{bcpAccentDark}  {HTML}{7B4E00}   % deep amber (print mode)
\definecolor{bcpAccentLight} {HTML}{FFF9E6}   % pale warm tint (callout backgrounds)
\definecolor{bcpAccentMid}   {HTML}{E8960A}   % bright amber (links, sub-headings)
\definecolor{bcpDark}        {HTML}{18181B}   % near-black charcoal (chapter bands, parts)

%% ─── Semantic callout colors ─────────────────────────────────────────────────
\definecolor{bcpNoteBlue}    {HTML}{1565C0}
\definecolor{bcpNoteBg}      {HTML}{E3F2FD}
\definecolor{bcpNoteBorder}  {HTML}{90CAF9}

\definecolor{bcpTipGreen}    {HTML}{2E7D32}
\definecolor{bcpTipBg}       {HTML}{E8F5E9}
\definecolor{bcpTipBorder}   {HTML}{A5D6A7}

\definecolor{bcpWarnAmber}   {HTML}{E65100}
\definecolor{bcpWarnBg}      {HTML}{FFF3E0}
\definecolor{bcpWarnBorder}  {HTML}{FFCC80}

\definecolor{bcpDangerRed}   {HTML}{B71C1C}
\definecolor{bcpDangerBg}    {HTML}{FFEBEE}
\definecolor{bcpDangerBorder}{HTML}{EF9A9A}

\definecolor{bcpExerciseTeal}{HTML}{00695C}
\definecolor{bcpExerciseBg}  {HTML}{E0F2F1}
\definecolor{bcpExerciseBorder}{HTML}{80CBC4}

\definecolor{bcpDefPurple}   {HTML}{4A148C}
\definecolor{bcpDefBg}       {HTML}{F3E5F5}
\definecolor{bcpDefBorder}   {HTML}{CE93D8}

\definecolor{bcpExampleGray} {HTML}{37474F}
\definecolor{bcpExampleBg}   {HTML}{ECEFF1}
\definecolor{bcpExampleBorder}{HTML}{B0BEC5}

\colorlet{bcpObjAccent}                    {bcpAccentBase}   % tracks book accent
\colorlet{bcpObjBg}                        {bcpAccentLight}  % tracks book accent light
\definecolor{bcpObjBorder}   {HTML}{E0B94A}                  % warm amber border

\definecolor{bcpSeeAlsoOrange}{HTML}{BF360C}
\definecolor{bcpSeeAlsoBg}    {HTML}{FBE9E7}
\definecolor{bcpSeeAlsoBorder}{HTML}{FFAB91}

%% ─── Code block colors ───────────────────────────────────────────────────────
\definecolor{bcpCodeBg}       {HTML}{F5F7FA}   % light gray code background (print+digital)
\definecolor{bcpCodeBorder}   {HTML}{D0D7E0}
\definecolor{bcpTermInBg}     {HTML}{1E1E2E}   % dark terminal background (digital only)
\definecolor{bcpTermInFg}     {HTML}{CDD6F4}   % terminal text (digital)
\definecolor{bcpTermInPrompt} {HTML}{A6E3A1}   % green prompt (digital)
\definecolor{bcpTermOutBg}    {HTML}{2A2A3E}   % slightly lighter than input (digital)
\definecolor{bcpTermOutFg}    {HTML}{BAC2DE}
\definecolor{bcpLineNum}      {HTML}{9AA5B4}   % line number color in code blocks
\definecolor{bcpHighlight}    {HTML}{FFF9C4}   % highlighted line background (light yellow)

%% ─── Print mode overrides ────────────────────────────────────────────────────
%% In print mode we keep the same color *names* but remap backgrounds to white
%% and foregrounds to grays/blacks. This means all package code is identical
%% for both modes — the color definitions simply change.
\if@bcpcolorprint

  %% Accent → dark gray-blue (prints well as solid dark)
  \colorlet{bcpAccent}     {bcpAccentDark}
  \colorlet{bcpAccentLight}{white}
  \colorlet{bcpAccentMid}  {bcpDarkGray}

  %% All callout backgrounds → white, borders → gray, text → dark
  \colorlet{bcpNoteBg}     {white}
  \colorlet{bcpNoteBorder} {bcpRule}
  \colorlet{bcpNoteBlue}   {bcpBlack}

  \colorlet{bcpTipBg}      {white}
  \colorlet{bcpTipBorder}  {bcpRule}
  \colorlet{bcpTipGreen}   {bcpBlack}

  \colorlet{bcpWarnBg}     {white}
  \colorlet{bcpWarnBorder} {bcpRule}
  \colorlet{bcpWarnAmber}  {bcpDarkGray}

  \colorlet{bcpDangerBg}   {white}
  \colorlet{bcpDangerBorder}{bcpRule}
  \colorlet{bcpDangerRed}  {bcpBlack}

  \colorlet{bcpExerciseBg}    {white}
  \colorlet{bcpExerciseBorder}{bcpRule}
  \colorlet{bcpExerciseTeal}  {bcpBlack}

  \colorlet{bcpDefBg}      {white}
  \colorlet{bcpDefBorder}  {bcpRule}
  \colorlet{bcpDefPurple}  {bcpBlack}

  \colorlet{bcpExampleBg}  {white}
  \colorlet{bcpExampleBorder}{bcpRule}
  \colorlet{bcpExampleGray}{bcpBlack}

  \colorlet{bcpObjBg}      {white}
  \colorlet{bcpObjBorder}  {bcpRule}
  \colorlet{bcpObjAccent}  {bcpBlack}

  \colorlet{bcpSeeAlsoBg}      {white}
  \colorlet{bcpSeeAlsoBorder}  {bcpRule}
  \colorlet{bcpSeeAlsoOrange}  {bcpDarkGray}

  %% Code blocks: keep light gray background in print (cheap, not true color)
  \colorlet{bcpTermInBg}   {bcpLightGray!30!white}
  \colorlet{bcpTermInFg}   {bcpBlack}
  \colorlet{bcpTermInPrompt}{bcpBlack}
  \colorlet{bcpTermOutBg}  {white}
  \colorlet{bcpTermOutFg}  {bcpBlack}

\else

  %% Digital defaults — use base colors as-is
  \colorlet{bcpAccent}     {bcpAccentBase}

\fi

%% ─── Semantic aliases used across the template ───────────────────────────────
%% These are the names that .sty files should reference (not the raw names above)
\colorlet{bcpTextMain}   {bcpBlack}
\colorlet{bcpTextSecond} {bcpDarkGray}
\colorlet{bcpTextLight}  {bcpMidGray}
\colorlet{bcpBorder}     {bcpRule}

\endinput
