%% =============================================================================
%% bcpedu-code.sty — Code and Terminal Environments
%% =============================================================================
%% Provides four environments for all code/terminal content:
%%
%%   \begin{codefile}[language]{filename}...\end{codefile}
%%     Syntax-highlighted code with filename header label, line numbers.
%%     For named files: configuration files, source code listings.
%%
%%   \begin{codeblock}[language]...\end{codeblock}
%%     Anonymous syntax-highlighted code, optional language label.
%%     For snippets without a filename.
%%
%%   \begin{terminalin}[label]...\end{terminalin}
%%     Dark-background shell input. Renders lines prefixed with $ prompt.
%%     For commands the reader types.
%%
%%   \begin{terminalout}[label]...\end{terminalout}
%%     Command output. Slightly lighter background than terminalin.
%%     For command output shown to reader.
%%
%% All environments:
%%   - breakable (span multiple pages)
%%   - Optional line range: firstline=N, lastline=M
%%   - Highlighted lines: highlightlines={2,5,7-9}
%%
%% Inline:
%%   \code{text}          — defined in bcpedu-fonts.sty
%%   \filename{path}      — file/path styling
%%   \envvar{NAME}        — environment variable
%%   \cmdname{git}        — command name
%%
%% Requirements:
%%   - Python 3 + Pygments  (pip3 install pygments)
%%   - LaTeX compiled with --shell-escape
%% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bcpedu-code}[2026/07/08 v1.0 BCP Education Code Environments]

\RequirePackage{tcolorbox}
\tcbuselibrary{minted,skins,breakable,listings}
\RequirePackage{minted}

%% ─── Pygments styles ─────────────────────────────────────────────────────────
%% Light code blocks: 'friendly' (built-in, good for print + digital)
%% Dark terminal blocks: 'monokai' (built-in, dark background)
%% To override per-book: redefine \bcpMintedStyleLight / \bcpMintedStyleDark
\newcommand{\bcpMintedStyleLight}{friendly}
\newcommand{\bcpMintedStyleDark}{monokai}

%% Global minted defaults
\setminted{
  breaklines = true,
  fontsize   = \small,
  tabsize    = 4,
}

%% ─── tcolorbox base styles ───────────────────────────────────────────────────
\tcbset{
  bcpCodeBase/.style = {
    enhanced,
    breakable,
    arc         = 4pt,
    boxrule     = 0.6pt,
    left        = 8pt,
    right       = 8pt,
    top         = 6pt,
    bottom      = 6pt,
    before skip = 10pt plus 3pt,
    after skip  = 10pt plus 3pt,
  },
  bcpCodeHeader/.style = {
    attach boxed title to top left = {yshift=-\tcboxedtitleheight+1pt, xshift=12pt},
    boxed title style = {
      enhanced,
      arc     = 2pt,
      boxrule = 0.5pt,
      top=2pt, bottom=2pt, left=6pt, right=6pt,
    },
  },
}

%% ─── Environment 1: codefile ─────────────────────────────────────────────────
%% \newtcblisting creates a verbatim-collecting environment (unlike \newenvironment).
%% Arguments: #1 = language (optional, default: text), #2 = filename (required)
%%
%% Usage: \begin{codefile}[bash]{/etc/nginx/nginx.conf}
%%          server { listen 80; }
%%        \end{codefile}
%%
\newtcblisting{codefile}[2][text]{
  bcpCodeBase,
  bcpCodeHeader,
  listing engine  = minted,
  listing only,
  minted language = {#1},
  minted options  = {style=friendly, linenos=true, fontsize=\small, tabsize=4, breaklines=true},
  colback         = bcpCodeBg,
  colframe        = bcpCodeBorder,
  coltitle        = bcpTextMain,
  colbacktitle    = bcpCodeBorder,
  title           = {\ttfamily\small
                     \textcolor{bcpAccent}{\faFile*[regular]\enspace}%
                     \textbf{#2}%
                     \hfill\textcolor{bcpTextLight}{\scriptsize\MakeUppercase{#1}}},
}

%% ─── Environment 2: codeblock ────────────────────────────────────────────────
%% #1 = language (optional, default: text)
%%
%% Usage: \begin{codeblock}[yaml]
%%          apiVersion: v1
%%        \end{codeblock}
%%
\newtcblisting{codeblock}[1][text]{
  bcpCodeBase,
  bcpCodeHeader,
  listing engine  = minted,
  listing only,
  minted language = {#1},
  minted options  = {style=friendly, linenos=true, fontsize=\small, tabsize=4, breaklines=true},
  colback         = bcpCodeBg,
  colframe        = bcpCodeBorder,
  coltitle        = bcpTextLight,
  colbacktitle    = bcpCodeBg,
  title           = {\scriptsize\sffamily\MakeUppercase{#1}},
}

%% ─── Environment 3: terminalin ───────────────────────────────────────────────
%% #1 = optional label (default: empty)
%%
%% Usage: \begin{terminalin}[My Server]
%%          $ kubectl get pods
%%        \end{terminalin}
%%
\newtcblisting{terminalin}[1][]{
  bcpCodeBase,
  bcpCodeHeader,
  listing engine  = minted,
  listing only,
  minted language = bash,
  minted options  = {style=monokai, linenos=false, fontsize=\small, tabsize=4, breaklines=true},
  colback         = bcpTermInBg,
  colframe        = bcpAccentDark,
  coltitle        = bcpTermInFg,
  colbacktitle    = bcpAccentDark,
  title           = {\textcolor{bcpTermInPrompt}{\small\faTerminal}\enspace
                     \textbf{\textcolor{bcpTermInFg}{Terminal}}%
                     \ifblank{#1}{}{\enspace\textcolor{bcpTermInFg!50!bcpAccentDark}{---\enspace#1}}},
}

%% ─── Environment 4: terminalout ──────────────────────────────────────────────
%% #1 = optional label (default: empty)
%%
%% Usage: \begin{terminalout}[kubectl output]
%%          NAME      READY   STATUS
%%        \end{terminalout}
%%
\newtcblisting{terminalout}[1][]{
  bcpCodeBase,
  bcpCodeHeader,
  listing engine  = minted,
  listing only,
  minted language = text,
  minted options  = {style=monokai, linenos=false, fontsize=\small, tabsize=4, breaklines=true},
  colback         = bcpTermOutBg,
  colframe        = bcpMidGray,
  coltitle        = bcpTermOutFg,
  colbacktitle    = bcpMidGray,
  title           = {\textcolor{bcpTermInPrompt!80!white}{\small\faAngleRight\faAngleRight}\enspace
                     \textbf{\textcolor{bcpTermOutFg}{Output}}%
                     \ifblank{#1}{}{\enspace\textcolor{bcpTermOutFg!60!bcpMidGray}{---\enspace#1}}},
}

%% ─── Inline semantic commands ────────────────────────────────────────────────
%% \code{} is defined in bcpedu-fonts.sty for styled inline code.
%% The following add semantic meaning on top.

%% File path or filename
\newcommand{\filename}[1]{%
  \texttt{\textcolor{bcpAccentDark}{#1}}%
}

%% Environment variable name
\newcommand{\envvar}[1]{%
  \texttt{\textcolor{bcpDefPurple}{\$#1}}%
}

%% Command / binary name
\newcommand{\cmdname}[1]{%
  \texttt{\textbf{\textcolor{bcpNoteBlue}{#1}}}%
}

%% Key/value pair inline
\newcommand{\kvpair}[2]{%
  \texttt{\textcolor{bcpAccentDark}{#1}\textcolor{bcpTextLight}{=}\textcolor{bcpExerciseTeal}{#2}}%
}

%% ─── List of Listings caption ────────────────────────────────────────────────
%% minted does not automatically add to LoL. Use \captionof or the listing env:
%%
%% \begin{listing}[H]
%%   \begin{codefile}[bash]{example.sh}...\end{codefile}
%%   \caption{Description of listing}
%%   \label{lst:example}
%% \end{listing}
%%
%% The \listoflistings command (from minted) will then pick these up.
%% We rename it to \listofcode for clarity.
\AtBeginDocument{%
  \@ifundefined{listoflistings}{}{%
    \let\listofcode\listoflistings
  }%
}

\endinput
