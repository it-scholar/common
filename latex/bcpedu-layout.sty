%% =============================================================================
%% bcpedu-layout.sty — Page Geometry and Running Headers/Footers
%% =============================================================================
%% Configures:
%%   - 7" × 10" page with KDP-compatible margins
%%   - Twoside layout with inner/outer margin asymmetry (binding allowance)
%%   - fancyhdr: chapter/section names in running heads, page numbers outside
%%   - Plain style for chapter-opening pages
%%   - Custom \cleardoublepage that inserts truly blank pages (no header)
%% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bcpedu-layout}[2026/07/08 v1.0 BCP Education Page Layout]

%% ─── Page geometry ───────────────────────────────────────────────────────────
%% 7" × 10" — KDP compatible, O'Reilly/Packt technical book standard
%% Margins ensure 300-1000 page books are comfortable to hold.
%%
%%   inner (binding side):  2.8cm — extra space for spine grip
%%   outer (cut edge):      2.2cm
%%   top:                   2.5cm (includes header)
%%   bottom:                3.0cm (includes footer, feels grounded)
%%   KDP minimum inner for perfect binding 300+ pages: ~1.27cm — we exceed this.
%%
\RequirePackage[
  paperwidth  = 7in,
  paperheight = 10in,
  twoside,
  inner       = 2.8cm,
  outer       = 2.2cm,
  top         = 2.5cm,
  bottom      = 3.0cm,
  headsep     = 0.5cm,
  footskip    = 1.2cm,
  includeheadfoot,
]{geometry}

%% ─── Running headers and footers ─────────────────────────────────────────────
\RequirePackage{fancyhdr}

%% Define the 'bcpedu' page style
\fancypagestyle{bcpedu}{%
  \fancyhf{}  % clear all fields
  %% Outer header: chapter/section name in small sans-serif caps
  %% Even pages (left): page number | chapter name
  \fancyhead[LE]{%
    \small\sffamily\textcolor{bcpTextLight}{\thepage}%
    \quad%
    \textcolor{bcpBorder}{\rule[-0.15ex]{0.5pt}{1.5ex}}%
    \quad%
    \textcolor{bcpTextSecond}{\nouppercase{\leftmark}}%
  }
  %% Odd pages (right): section name | page number
  \fancyhead[RO]{%
    \small\sffamily%
    \textcolor{bcpTextSecond}{\nouppercase{\rightmark}}%
    \quad%
    \textcolor{bcpBorder}{\rule[-0.15ex]{0.5pt}{1.5ex}}%
    \quad%
    \textcolor{bcpTextLight}{\thepage}%
  }
  %% Footer: series name centered, accent-colored thin rule above
  \fancyfoot[C]{%
    \color{bcpBorder}\rule{\textwidth}{0.4pt}\\[2pt]
    \small\sffamily\textcolor{bcpTextLight}{\@bookseries}%
  }
  %% Header rule: thin accent-colored line
  \renewcommand{\headrulewidth}{0pt}  % we draw our own rule via colors
  \renewcommand{\footrulewidth}{0pt}
}

%% Plain style: for chapter-opening pages, part pages, ToC pages
\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyfoot[C]{%
    \color{bcpBorder}\rule{\textwidth}{0.4pt}\\[2pt]
    \small\sffamily\textcolor{bcpTextLight}{\thepage}%
  }
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

%% Empty style: for true blank pages between chapters
\fancypagestyle{empty}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

%% Apply the bcpedu page style globally
\pagestyle{bcpedu}

%% ─── Mark format ─────────────────────────────────────────────────────────────
%% \chaptermark and \sectionmark set \leftmark and \rightmark.
%% We want: CHAPTER N — Chapter Title   |   Section Title
\renewcommand{\chaptermark}[1]{%
  \markboth{\chaptername\ \thechapter\ \textemdash\ #1}{#1}%
}
\renewcommand{\sectionmark}[1]{%
  \markright{#1}%
}

%% ─── Clean double-page-clear ─────────────────────────────────────────────────
%% Insert a truly blank page (no headers/footers) when forcing chapter to recto.
\renewcommand{\cleardoublepage}{%
  \clearpage
  \if@twoside
    \ifodd\c@page\else
      \thispagestyle{empty}%
      \hbox{}\newpage
      \if@twocolumn\hbox{}\newpage\fi
    \fi
  \fi
}

%% ─── Text block parameters ───────────────────────────────────────────────────
%% Widow/orphan control: prevent isolated lines at top/bottom of pages.
\widowpenalty  = 10000
\clubpenalty   = 10000
\displaywidowpenalty = 10000

%% Allow slightly looser spacing rather than an overfull box.
\tolerance     = 1000
\emergencystretch = 2em
\hfuzz         = 0.5pt

%% ─── Column separation (for multi-column sections, e.g. index) ───────────────
\setlength{\columnsep}{1.5em}
\setlength{\columnseprule}{0.4pt}
%% \columnseprulecolor is a multicol package command; set it only when available.
\AtBeginDocument{%
  \@ifpackageloaded{multicol}{%
    \renewcommand{\columnseprulecolor}{\color{bcpBorder}}%
  }{}%
}

\endinput
