%% =============================================================================
%% bcpedu-headings.sty — Chapter, Section, and Part Heading Styles
%% =============================================================================
%% Design: Editorial Minimalism — follows BCP corporate design language.
%%
%%   \part       — white page, ghost number (TikZ), gold square + label, big title
%%   \chapter    — white page, ghost number (TikZ), gold square + "CHAPTER N" label,
%%                 hairline rule, bold title 28pt
%%   \section    — gold filled square + number, generous spacing, no rule
%%   \subsection — gray filled square + number
%%   \subsubsection — small gray square + number, lighter text
%%   \paragraph  — bold sans inline
%%
%% All structural decoration uses a single gold color (bcpAccent).
%% No background bands, no underrules on sections. White space does the work.
%% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bcpedu-headings}[2026/07/08 v2.0 BCP Education Heading Styles]

\RequirePackage{titlesec}
\RequirePackage{titletoc}   % ToC entry styling
\RequirePackage{needspace}  % prevent floating headings

%% ─── Reusable decoration macros ──────────────────────────────────────────────
%% Gold filled square (matches business plan \goldsq)
\newcommand{\bcpGoldSq}{\raisebox{0.18em}{\textcolor{bcpAccent}{\rule{0.42em}{0.42em}}}}
%% Gray filled square for sub-levels
\newcommand{\bcpGraySq}{\raisebox{0.15em}{\textcolor{black!28}{\rule{0.32em}{0.32em}}}}

%% ─── Part pages ──────────────────────────────────────────────────────────────
%% White page, ghost part number via TikZ overlay, gold square label, big title.
\titleformat{\part}[display]
  {\thispagestyle{empty}\sffamily\bfseries}
  {%
    %% Ghost part number — bottom-right, nearly invisible
    \begin{tikzpicture}[overlay, remember picture]
      \node[
        anchor = south east,
        xshift = -1.8cm, yshift = 2.0cm,
        font   = \fontsize{200}{200}\selectfont\sffamily\bfseries\color{black!5},
      ] at (current page.south east) {\thepart};
    \end{tikzpicture}%
    %% Gold square + "PART N" label
    \bcpGoldSq\enspace
    {\footnotesize\sffamily\color{bcpTextLight}%
      \MakeUppercase{\partname}\enspace\thepart}%
    \\[0.5em]%
    %% Hairline separator
    {\color{black!12}\rule{\linewidth}{0.4pt}}%
  }
  {1.2em}
  {\fontsize{42pt}{48pt}\selectfont\color{bcpTextMain}}

\titlespacing*{\part}
  {0pt}   % left indent
  {3.5cm} % top space before label
  {0pt}   % after (no extra after-code space needed)

%% ─── Chapter headings ────────────────────────────────────────────────────────
%% White page, ghost chapter number (TikZ), gold square + label, hairline, title.
\titleformat{\chapter}[display]
  {\sffamily}
  {%
    %% Ghost chapter number — bottom-right corner, very pale
    \begin{tikzpicture}[overlay, remember picture]
      \node[
        anchor = south east,
        xshift = -1.8cm, yshift = 2.0cm,
        font   = \fontsize{160}{160}\selectfont\sffamily\bfseries\color{black!5},
      ] at (current page.south east) {\thechapter};
    \end{tikzpicture}%
    %% Gold square + "CHAPTER N" label — tiny, gray, uppercase
    \bcpGoldSq\enspace
    {\footnotesize\sffamily\color{bcpTextLight}%
      \MakeUppercase{\chaptername}\enspace\thechapter}%
    \\[0.5em]%
    %% Hairline separator rule (matches business plan \chapterlinesformat)
    {\color{black!12}\rule{\linewidth}{0.4pt}}%
  }
  {1.2em}
  {\raggedright\bfseries\fontsize{28pt}{34pt}\selectfont\color{bcpTextMain}}
  [\vspace{2.0cm}]

\titlespacing*{\chapter}
  {0pt}   % left indent
  {3.5cm} % top space before label (matches \vspace*{3.5cm} in business plan)
  {0pt}   % after (after-code \vspace{2.0cm} handles paragraph gap)

%% ─── Section ─────────────────────────────────────────────────────────────────
%% Gold square + number, bold sans. No rule. Space alone creates hierarchy.
\titleformat{\section}
  {\needspace{4\baselineskip}\sffamily\bfseries\fontScaleXL\color{bcpTextMain}}
  {\bcpGoldSq\enspace\thesection\enspace}
  {0pt}
  {}

\titlespacing*{\section}
  {0pt}{22pt plus 4pt minus 2pt}{9pt plus 2pt}

%% ─── Subsection ──────────────────────────────────────────────────────────────
%% Gray square + number, bold sans, slightly smaller.
\titleformat{\subsection}
  {\needspace{3\baselineskip}\sffamily\bfseries\fontScaleL\color{bcpTextMain}}
  {\bcpGraySq\enspace\thesubsection\enspace}
  {0pt}
  {}

\titlespacing*{\subsection}
  {0pt}{16pt plus 3pt minus 2pt}{6pt plus 1pt}

%% ─── Subsubsection ───────────────────────────────────────────────────────────
%% Tiny gray square + number, lighter text weight.
\titleformat{\subsubsection}
  {\needspace{2\baselineskip}\sffamily\bfseries\normalsize\color{bcpTextSecond}}
  {{\raisebox{0.12em}{\textcolor{black!20}{\rule{0.26em}{0.26em}}}}\enspace\thesubsubsection\enspace}
  {0pt}
  {}

\titlespacing*{\subsubsection}
  {0pt}{12pt plus 2pt minus 1pt}{4pt}

%% ─── Paragraph and subparagraph ──────────────────────────────────────────────
\titleformat{\paragraph}[runin]
  {\sffamily\bfseries\normalsize\color{bcpTextMain}}
  {}
  {0pt}
  {}
  [.\enspace]

\titleformat{\subparagraph}[runin]
  {\sffamily\itshape\normalsize\color{bcpTextSecond}}
  {}
  {0pt}
  {}
  [.\enspace]

%% ─── Table of Contents entry formatting ──────────────────────────────────────
\setcounter{tocdepth}{2}
\setcounter{secnumdepth}{3}

%% Part: gold square + part name, large bold
\titlecontents{part}
  [0em]
  {\addvspace{12pt}\sffamily\bfseries\fontScaleL}
  {\bcpGoldSq\enspace\partname\enspace\thecontentslabel\quad}
  {}
  {}

%% Chapter: gold square + number, bold, page number right, hairline below
\titlecontents{chapter}
  [0em]
  {\addvspace{8pt}\sffamily\bfseries\normalsize}
  {\bcpGoldSq\enspace\makebox[1.8em][l]{\thecontentslabel}}
  {}
  {\hfill\textbf{\contentspage}}
  [\vspace{3pt}{\color{black!10}\hrule height 0.4pt}\vspace{1pt}]

%% Section: gray square + number, small, dot leaders
\titlecontents{section}
  [2.5em]
  {\addvspace{2pt}\sffamily\small}
  {\bcpGraySq\enspace\makebox[2.0em][l]{\thecontentslabel}}
  {}
  {\titlerule*[0.5em]{\textcolor{black!18}{.}}\contentspage}

%% Subsection: small gray, more indented, dot leaders
\titlecontents{subsection}
  [5.0em]
  {\sffamily\small\color{bcpTextSecond}}
  {\makebox[2.8em][l]{\thecontentslabel}}
  {}
  {\titlerule*[0.5em]{\textcolor{black!15}{.}}\contentspage}

%% ─── Appendix heading re-labeling ────────────────────────────────────────────
%% After \appendix, \chaptername changes to \appendixname automatically.

\endinput
